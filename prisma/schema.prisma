generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum TaskStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum AgentType {
  CHAT
  PLAN
  EXECUTOR
  REVIEW
}

enum AgentSessionStatus {
  STARTING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String?   @unique
  passwordHash  String    @map("password_hash")
  displayName   String?   @map("display_name")
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  conversations     Conversation[]
  tasks             Task[]
  agentSessions     AgentSession[]
  createdTestCases  TestCase[]   @relation("TestCaseCreator")
  reviewedTestCases TestCase[]   @relation("TestCaseReviewer")
  testReports       TestReport[]
  createdDefects       Defect[]        @relation("DefectCreator")
  createdDefectComments DefectComment[] @relation("DefectCommentCreator")

  @@map("users")
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  messages Message[]
  agentSessions AgentSession[]
  coordinatorPlan CoordinatorPlan?
  testReports TestReport[]

  @@index([userId])
  @@index([createdAt])
  @@map("conversations")
}

model CoordinatorPlan {
  id              String   @id @default(uuid())
  conversationId  String   @unique @map("conversation_id")
  objective       String   @db.Text
  plan            Json     // 完整的执行计划 (phases, workers, etc.)
  activePhase     Int?     @map("active_phase")
  completedPhases Int[]    @default([]) @map("completed_phases")
  phaseOutputs    Json?    @map("phase_outputs")
  status          String   @default("running") // running, completed, failed
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("coordinator_plans")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String   @db.Text
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

model Task {
  id           String     @id @default(uuid())
  userId       String?    @map("user_id")
  taskType     String     @map("task_type")
  status       TaskStatus @default(PENDING)
  parameters   Json?
  result       Json?
  checkpoint   Json?
  errorMessage String?    @map("error_message") @db.Text
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  startedAt    DateTime?  @map("started_at")
  completedAt  DateTime?  @map("completed_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([taskType])
  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@map("tasks")
}

// ─── Mock 被测系统：MODEL_001 授信额度测算 ───────────────────────────────────

model MockUserInfo {
  userId    String @id @map("user_id")
  userLevel Int    @map("user_level")

  @@map("mock_user_info")
}

model MockAccountBalance {
  userId       String  @id @map("user_id")
  avg3mBalance Decimal @map("avg_3m_balance")

  @@map("mock_account_balance")
}

model MockSocialSecurity {
  userId             String @id @map("user_id")
  socialSecurityFlag Int    @map("social_security_flag")

  @@map("mock_social_security")
}

model MockSalarySummary {
  userId        String  @id @map("user_id")
  monthlySalary Decimal @map("monthly_salary")

  @@map("mock_salary_summary")
}

// ─────────────────────────────────────────────────────────────────────────────

model AgentSession {
  id             String             @id @default(uuid())
  conversationId String             @map("conversation_id")
  userId         String             @map("user_id")
  replyId        String             @unique @map("reply_id")
  agentType      AgentType          @default(CHAT) @map("agent_type")
  status         AgentSessionStatus @default(STARTING)
  pid            Int?
  metadata       Json?
  startedAt      DateTime           @default(now()) @map("started_at")
  finishedAt     DateTime?          @map("finished_at")
  errorMessage   String?            @map("error_message") @db.Text

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([conversationId])
  @@index([replyId])
  @@index([status])
  @@map("agent_sessions")
}

enum TestCaseStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  BASELINE
  DEPRECATED
}

enum ExecutionStatus {
  PASS
  FAIL
  ERROR
  SKIP
}

model TestCaseGroup {
  id        String   @id @default(uuid())
  modelId   String   @map("model_id")
  caseCode  String   @map("case_code")
  latestId  String?  @map("latest_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  versions TestCase[]

  @@unique([modelId, caseCode])
  @@index([modelId])
  @@map("test_case_groups")
}

model TestCase {
  id             String         @id @default(uuid())
  groupId        String         @map("group_id")
  version        Int            @default(1)
  status         TestCaseStatus @default(DRAFT)
  title          String
  coveragePoint  String?        @map("coverage_point")
  priority       String         @default("P2")
  inputParams    Json?          @map("input_params")
  expectedResult Json?          @map("expected_result")
  yamlContent    String?        @map("yaml_content") @db.Text
  notes          String?        @db.Text
  tags           String[]       @default([])
  conversationId String?        @map("conversation_id")
  sourceMode     String?        @map("source_mode")
  reportId       String?        @map("report_id")
  createdBy      String         @map("created_by")
  reviewedBy     String?        @map("reviewed_by")
  reviewNote     String?        @map("review_note")
  reviewedAt     DateTime?      @map("reviewed_at")
  baselinedAt    DateTime?      @map("baselined_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  group      TestCaseGroup   @relation(fields: [groupId], references: [id])
  creator    User            @relation("TestCaseCreator", fields: [createdBy], references: [id])
  reviewer   User?           @relation("TestCaseReviewer", fields: [reviewedBy], references: [id])
  executions TestExecution[]
  report     TestReport?     @relation(fields: [reportId], references: [id])
  defects    Defect[]

  @@unique([groupId, version])
  @@index([status])
  @@index([groupId])
  @@index([conversationId])
  @@map("test_cases")
}

model TestExecution {
  id             String          @id @default(uuid())
  testCaseId     String          @map("test_case_id")
  conversationId String?         @map("conversation_id")
  status         ExecutionStatus
  baseUrl        String?         @map("base_url")
  actualResult   Json?           @map("actual_result")
  errorMessage   String?         @map("error_message") @db.Text
  durationMs     Int?            @map("duration_ms")
  executedAt     DateTime        @default(now()) @map("executed_at")
  executedBy     String?         @map("executed_by")

  testCase TestCase @relation(fields: [testCaseId], references: [id])

  @@index([testCaseId])
  @@index([conversationId])
  @@index([status])
  @@index([executedAt])
  @@map("test_executions")
}

model TestReport {
  id             String   @id @default(uuid())
  name           String
  conversationId String   @map("conversation_id")
  executionMode  String?  @map("execution_mode")
  htmlFile       String   @map("html_file")
  testCasesData  Json?    @map("test_cases_data")
  casesImported  Boolean  @default(false) @map("cases_imported")
  uploadedDocs   String[] @default([]) @map("uploaded_docs")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [createdBy], references: [id])
  testCases    TestCase[]
  defects      Defect[]

  @@index([conversationId])
  @@index([createdBy])
  @@map("test_reports")
}

model Defect {
  id             String    @id @default(uuid())
  title          String
  status         String    @default("待处理")
  severity       String    @default("P2")
  description    String?   @db.Text
  reportId       String?   @map("report_id")
  testCaseId     String?   @map("test_case_id")
  conversationId String?   @map("conversation_id")
  createdBy      String    @map("created_by")
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  report     TestReport?    @relation(fields: [reportId], references: [id])
  testCase   TestCase?      @relation(fields: [testCaseId], references: [id])
  creator    User           @relation("DefectCreator", fields: [createdBy], references: [id])
  comments   DefectComment[]

  @@index([status])
  @@index([reportId])
  @@index([testCaseId])
  @@index([createdBy])
  @@map("defects")
}

model DefectComment {
  id        String   @id @default(uuid())
  defectId  String   @map("defect_id")
  content   String   @db.Text
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  defect  Defect @relation(fields: [defectId], references: [id], onDelete: Cascade)
  creator User   @relation("DefectCommentCreator", fields: [createdBy], references: [id])

  @@index([defectId])
  @@map("defect_comments")
}
